{
  "name": "Solyra Order → WhatsApp (Darija)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "solyra-order-whatsapp",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "a1b2c3d4-order-webhook",
      "name": "Order Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "solyra-order-whatsapp"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{ $env.META_PHONE_NUMBER_ID }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.META_ACCESS_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $json.body.phone_e164.replace('+', '') }}\",\n  \"type\": \"template\",\n  \"template\": {\n    \"name\": \"{{ $env.META_TEMPLATE_NAME }}\",\n    \"language\": { \"code\": \"{{ $env.META_TEMPLATE_LANG || 'ar' }}\" },\n    \"components\": [\n      {\n        \"type\": \"body\",\n        \"parameters\": [\n          { \"type\": \"text\", \"text\": \"{{ $json.body.customer_name }}\" },\n          { \"type\": \"text\", \"text\": \"{{ $json.body.order_number }}\" },\n          { \"type\": \"text\", \"text\": \"{{ $json.body.items_text }}\" },\n          { \"type\": \"text\", \"text\": \"{{ $json.body.total_mad }}\" }\n        ]\n      },\n      {\n        \"type\": \"button\",\n        \"sub_type\": \"quick_reply\",\n        \"index\": \"0\",\n        \"parameters\": [{ \"type\": \"payload\", \"payload\": \"wa_confirm\" }]\n      },\n      {\n        \"type\": \"button\",\n        \"sub_type\": \"quick_reply\",\n        \"index\": \"1\",\n        \"parameters\": [{ \"type\": \"payload\", \"payload\": \"wa_cancel\" }]\n      },\n      {\n        \"type\": \"button\",\n        \"sub_type\": \"quick_reply\",\n        \"index\": \"2\",\n        \"parameters\": [{ \"type\": \"payload\", \"payload\": \"wa_modify\" }]\n      }\n    ]\n  }\n}",
        "options": {}
      },
      "id": "b2c3d4e5-send-template",
      "name": "Send Darija Template",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300]
    }
  ],
  "connections": {
    "Order Webhook": {
      "main": [
        [
          {
            "node": "Send Darija Template",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "templateCredsSetupCompleted": false
  }
}
