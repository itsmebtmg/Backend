APP_ENV=production
APP_NAME=Solyra API
API_BASE_URL=https://api.solyra.ma
FRONTEND_URL=https://solyra.ma

DATABASE_URL=postgresql+asyncpg://solyra:solyra@solyra_database:5432/solyra
ALEMBIC_DATABASE_URL=postgresql://solyra:solyra@solyra_database:5432/solyra

CORS_ORIGINS=https://solyra.ma,http://localhost:3000

GOOGLE_SHEETS_WEBHOOK_URL=
# Shared secret the Google Sheet's "Status" onEdit trigger sends back to
# POST /v1/orders/sheet-status. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
ORDER_WEBHOOK_SECRET=

META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=
SNAP_TEST_EVENT_CODE=

ENABLE_CAPI=true
ENABLE_GOOGLE_SHEETS=true
ENABLE_N8N_WHATSAPP=false
N8N_ORDER_WEBHOOK_URL=
TRACKING_DEBUG=false

RATE_LIMIT_ORDERS_PER_IP_PER_HOUR=10
RATE_LIMIT_ORDERS_PER_PHONE_PER_DAY=3

# --- Admin dashboard ---------------------------------------------------
# Single shared admin login (no user table). Change these before deploying.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_EXPIRE_MINUTES=720
ADMIN_COOKIE_NAME=solyra_admin_session
# Set to false only for local http:// development
ADMIN_COOKIE_SECURE=true

# --- Geo / VPN detection (MaxMind GeoIP2 web service) -------------------
# Same MaxMind account already used by the frontend checkout guard. Backend
# needs its own copy so it can geo/VPN-check clicks and orders server-side.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# --- Shipping / delivery -------------------------------------------------
# Leave as "manual" until you have a shipping company API. Admins can set
# delivery status by hand in the dashboard in the meantime.
SHIPPING_PROVIDER=manual
SHIPPING_API_BASE_URL=
SHIPPING_API_KEY=
